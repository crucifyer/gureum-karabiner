{
	"description": "Home/End를 줄 맨 앞/뒤 이동으로 변경",
	"manipulators": [
		{
			"conditions": [
				{
					"bundle_identifiers": [
						"^com\\.tinyspeck\\.slackmacgap$",
						"^com\\.google\\.Chrome$",
						"^com\\.apple\\.Safari$",
						"^com\\.microsoft\\.edgemac$",
						"^org\\.mozilla\\.firefox$",
						"^com\\.operasoftware\\.Opera$",
						"^com\\.naver\\.Whale$",
						"^com\\.apple\\.dt\\.Xcode$",
						"^com\\.openai\\.codex$",
						"^com\\.google\\.antigravity-ide$",
						"^com\\.anthropic\\.claudefordesktop$",
						"^ai\\.opencode\\.desktop$",
						"^ru\\.keepcoder\\.Telegram$"
					],
					"type": "frontmost_application_if"
				}
			],
			"description": "Ctrl+A",
			"from": {
				"key_code": "home",
				"modifiers": { "optional": ["shift"] }
			},
			"to": [
				{
					"key_code": "a",
					"modifiers": ["left_control"]
				}
			],
			"type": "basic"
		},
		{
			"conditions": [
				{
					"bundle_identifiers": [
						"^com\\.tinyspeck\\.slackmacgap$",
						"^com\\.google\\.Chrome$",
						"^com\\.apple\\.Safari$",
						"^com\\.microsoft\\.edgemac$",
						"^org\\.mozilla\\.firefox$",
						"^com\\.operasoftware\\.Opera$",
						"^com\\.naver\\.Whale$",
						"^com\\.apple\\.dt\\.Xcode$",
						"^com\\.openai\\.codex$",
						"^com\\.google\\.antigravity-ide$",
						"^com\\.anthropic\\.claudefordesktop$",
						"^ai\\.opencode\\.desktop$",
						"^ru\\.keepcoder\\.Telegram$"
					],
					"type": "frontmost_application_if"
				}
			],
			"description": "Ctrl+E",
			"from": {
				"key_code": "end",
				"modifiers": { "optional": ["shift"] }
			},
			"to": [
				{
					"key_code": "e",
					"modifiers": ["left_control"]
				}
			],
			"type": "basic"
		},
		{
			"conditions": [
				{
					"bundle_identifiers": [
						"^com\\.playmoreai\\.mark$"
					],
					"type": "frontmost_application_if"
				}
			],
			"description": "Cmd+Left",
			"from": {
				"key_code": "home",
				"modifiers": { "optional": ["shift"] }
			},
			"to": [
				{
					"key_code": "left_arrow",
					"modifiers": ["left_command"]
				}
			],
			"type": "basic"
		},
		{
			"conditions": [
				{
					"bundle_identifiers": [
						"^com\\.playmoreai\\.mark$"
					],
					"type": "frontmost_application_if"
				}
			],
			"description": "Cmd+Right",
			"from": {
				"key_code": "end",
				"modifiers": { "optional": ["shift"] }
			},
			"to": [
				{
					"key_code": "right_arrow",
					"modifiers": ["left_command"]
				}
			],
			"type": "basic"
		}
	]
}