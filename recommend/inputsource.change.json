{
	"description": "입력소스 전환: 구름<>애플 토글 right cmd + option + (1 애플한글, 2 구름한글, 3 히라가나, 4 가타카나)",
	"manipulators": [
		{
			"conditions": [
				{
					"bundle_identifiers": [
						"^com\\.google\\.Chrome\\.app\\.cmkncekebbebpfilplodngbpllndjkfo$",
						"^com\\.utmapp\\.UTM$",
						"^com\\.microsoft\\.rdc\\.macos$"
					],
					"description": "원격/가상 데스크탑 제외",
					"type": "frontmost_application_unless"
				}
			],
			"description": "구름 입력기 한글 cmd + option + 1",
			"from": {
				"key_code": "1",
				"modifiers": { "mandatory": ["right_command", "right_option"] }
			},
			"to": [{ "shell_command": "/opt/homebrew/bin/macism org.youknowone.inputmethod.Gureum.han2" }],
			"type": "basic"
		},
		{
			"conditions": [
				{
					"bundle_identifiers": [
						"^com\\.google\\.Chrome\\.app\\.cmkncekebbebpfilplodngbpllndjkfo$",
						"^com\\.utmapp\\.UTM$",
						"^com\\.microsoft\\.rdc\\.macos$"
					],
					"description": "원격/가상 데스크탑 제외",
					"type": "frontmost_application_unless"
				}
			],
			"description": "기본 한글 cmd + option + 2",
			"from": {
				"key_code": "2",
				"modifiers": { "mandatory": ["right_command", "right_option"] }
			},
			"to": [{ "shell_command": "/opt/homebrew/bin/macism com.apple.inputmethod.Korean.2SetKorean" }],
			"type": "basic"
		},
		{
			"conditions": [
				{
					"bundle_identifiers": [
