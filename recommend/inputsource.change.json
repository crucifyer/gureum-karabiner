				"key_code": "3",
				"modifiers": { "mandatory": ["right_command", "right_option"] }
			},
			"to": [{ "shell_command": "/opt/homebrew/bin/macism com.apple.inputmethod.Kotoeri.RomajiTyping.Japanese" }],
			"type": "basic"
		},
		{
			"conditions": [
				{
					"bundle_identifiers": [
						"^com\\.google\\.Chrome\\.app\\.cmkncekebbebpfilplodngbpllndjkfo$",
